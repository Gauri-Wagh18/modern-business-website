package com.internship.dto;

public class UserResponseDto {

    private Long id;
    private String name;
    private String email;
    private String role;

    // ✅ No-args constructor (IMPORTANT for Jackson / serialization)
    public UserResponseDto() {
    }

    // ✅ Required constructor (used in service layer)
    public UserResponseDto(Long id, String name, String email, String role) {
        this.id = id;
        this.name = name;
        this.email = email;
        this.role = role;
    }

    // 🔹 Getters
    public Long getId() {
        return id;
    }

    public String getName() {
        return name;
    }

    public String getEmail() {
        return email;
    }

    public String getRole() {
        return role;
    }
}
